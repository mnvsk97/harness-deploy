TFY_WORKSPACE_FQN=cluster-id:workspace-name
TFY_SECRET_TENANT=your-tenant
HARNESS_DEPLOY_ROOT=/absolute/path/to/harness-deploy

TFY_GATEWAY_SECRET_GROUP=codex-tfy-gateway-secrets
CODEX_GATEWAY_SECRET_GROUP=codex-gateway-secrets
CLAUDE_CODE_GATEWAY_SECRET_GROUP=claude-code-gateway-secrets
SLACK_SECRET_GROUP=slack-secrets
SLACK_APP_CONFIG_TOKEN=
SLACK_TEAM_ID=

CODEX_GATEWAY_HOST=codex-http-gateway.example.truefoundry.cloud
CODEX_SLACK_HOST=codex-slack.example.truefoundry.cloud
CODEX_SLACK_SECRET_GROUP=codex-slack-gateway-secrets
CODEX_SLACK_APP_NAME=Codex
CODEX_SLACK_STORAGE_CLASS=managed-csi-premium
CLAUDE_CODE_GATEWAY_HOST=claude-code-gateway.example.truefoundry.cloud
CLAUDE_CODE_GATEWAY_URL=https://claude-code-gateway.example.truefoundry.cloud
CLAUDE_CODE_SLACK_HOST=claude-code-slack.example.truefoundry.cloud
CLAUDE_CODE_SLACK_SECRET_GROUP=claude-code-slack-secrets
HERMES_API_HOST=hermes-api.example.truefoundry.cloud
HERMES_API_TOKEN=
GOOSE_API_HOST=goose-api.example.truefoundry.cloud
GOOSE_MODEL=openai-main/gpt-5.5
GOOSE_SECRET_GROUP=goose-api-secrets
GOOSE_SECRET_INTEGRATION_FQN=tenant:provider:cluster:secret-store:name
GOOSE_SECRET_ADMIN_EMAIL=admin@example.com
GOOSE_STORAGE_CLASS=managed-csi-premium
GOOSE_SLACK_HOST=goose-slack.example.truefoundry.cloud
GOOSE_SLACK_SECRET_GROUP=goose-slack-gateway-secrets
GOOSE_SLACK_APP_NAME=Goose
GOOSE_SLACK_STORAGE_CLASS=managed-csi-premium
OPENSWE_API_HOST=openswe.example.truefoundry.cloud
OPENSWE_SECRET_GROUP=openswe-secrets
OPENSWE_DEFAULT_REPO=owner/repo
OPENSWE_SECRET_INTEGRATION_FQN=tenant:provider:cluster:secret-store:name
OPENSWE_SECRET_ADMIN_SUBJECT=user:admin@example.com
OPENSWE_SLACK_HOST=openswe-slack.example.truefoundry.cloud
OPENSWE_SLACK_SECRET_GROUP=openswe-slack-gateway-secrets
OPENSWE_SLACK_APP_NAME=Open SWE
OPENSWE_SLACK_STORAGE_CLASS=managed-csi-premium
DAYTONA_API_KEY=
PI_GATEWAY_HOST=pi-steppable-gateway.example.truefoundry.cloud
PI_MODEL=openai-main/gpt-5.5
PI_THINKING=off
PI_STORAGE_CLASS=managed-csi-premium
PI_SLACK_HOST=pi-slack.example.truefoundry.cloud
PI_SLACK_SECRET_GROUP=pi-slack-gateway-secrets
PI_SLACK_APP_NAME=Pi
PI_SLACK_STORAGE_CLASS=managed-csi-premium
PI_DAYTONA_SECRET_GROUP=pi-daytona-secrets
PI_DAYTONA_IMAGE=node:22-bookworm
DAYTONA_API_KEY=

SLACK_BRIDGE_HARNESS_NAME=codex
SLACK_BRIDGE_HARNESS_API_URL=https://codex-http-gateway.example.truefoundry.cloud
SLACK_BRIDGE_TARGET_SECRET_GROUP=codex-gateway-secrets
SLACK_BRIDGE_TARGET_TOKEN_KEY=CODEX-GATEWAY-BEARER-TOKEN
SLACK_BRIDGE_AUTH_HEADER=authorization
SLACK_BRIDGE_AUTH_SCHEME=Bearer
SLACK_BRIDGE_BODY_PROFILE=generic
SLACK_BRIDGE_SEND_INITIAL_MESSAGE_AFTER_CREATE=false
SLACK_BRIDGE_WORKING_DIR=/data/workspaces/slack
SLACK_BRIDGE_SESSION_CREATE_PATH=/sessions
SLACK_BRIDGE_SESSION_MESSAGE_PATH_TEMPLATE=/sessions/{session_id}/messages
SLACK_BRIDGE_SESSION_EVENTS_PATH_TEMPLATE=/sessions/{session_id}/events
SLACK_BRIDGE_POLL_EVENTS=true
